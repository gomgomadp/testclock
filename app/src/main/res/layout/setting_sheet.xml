<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView android:text="시간 글자 크기"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />
    <SeekBar android:id="@+id/seekFontSize" android:max="24"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />

    <TextView
        android:id="@+id/labelDateFormat"
        android:text="날짜 표시 형식"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp" />

    <Spinner
        android:id="@+id/spinnerDateFormat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <EditText
        android:id="@+id/editCustomDateFormat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="예: yyyy/MM/dd E"
        android:visibility="gone" />

    <TextView
        android:id="@+id/labelDateFontSize"
        android:text="날짜 글자 크기"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <SeekBar
        android:id="@+id/seekDateFontSize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />


    <TextView android:text="초 표시"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        />
    <Switch android:id="@+id/switchSeconds"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />

    <TextView android:text="야간 모드"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />
    <Switch android:id="@+id/switchNight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />

    <TextView android:text="설정 아이콘 흰색"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />
    <Switch android:id="@+id/switchIconWhite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />

    <Button
        android:id="@+id/buttonSave"
        android:text="저장"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        />

    <TextView
        android:id="@+id/labelSaved"
        android:text="✔ 저장됨"
        android:textColor="#555555"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />
</LinearLayout>