<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView android:text="글자 크기"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />
    <SeekBar android:id="@+id/seekFontSize" android:max="24"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />

    <TextView android:text="초 표시"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />
    <Switch android:id="@+id/switchSeconds"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />

    <TextView android:text="야간 모드"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />
    <Switch android:id="@+id/switchNight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />

    <Button
        android:id="@+id/buttonSave"
        android:text="저장"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />

    <TextView
        android:id="@+id/labelSaved"
        android:text="✔ 저장됨"
        android:textColor="#555555"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        />
</LinearLayout>